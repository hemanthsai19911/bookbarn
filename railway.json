{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "cd bookapp && mvn clean package -DskipTests"
    },
    "deploy": {
        "startCommand": "cd bookapp && java -Dserver.port=$PORT -jar target/book-0.0.1-SNAPSHOT.jar",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}