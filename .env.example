# Railway Environment Variables Template
# Copy these to your Railway project settings

# Database (Railway MySQL provides these automatically)
MYSQL_URL=jdbc:mysql://host:port/database?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
MYSQL_USER=root
MYSQL_PASSWORD=your-database-password

# Server Port (Railway sets this automatically)
PORT=8080

# Email Configuration (Gmail)
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# JWT Secret (Generate a new one for production!)
# Generate with: openssl rand -base64 32
JWT_SECRET=nLkPvZ3CJMb2pZVZ6oWRqF2u3Tt0tV8J5c71v0Z5XgA=

# Notes:
# - MYSQL_URL, MYSQL_USER, MYSQL_PASSWORD, and PORT are set automatically by Railway
# - You MUST set EMAIL_USERNAME and EMAIL_PASSWORD manually
# - Generate a new JWT_SECRET for production (don't use the default!)
